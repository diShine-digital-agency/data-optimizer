# ──────────────────────────────────────────────────────────────────────
#  Dishine Convert — environment variables
#  Copy this file to `.env` and fill in the values you need.
#  NEVER commit a populated `.env` file.
# ──────────────────────────────────────────────────────────────────────

# ─── Front-end (Vite) ──────────────────────────────────────────────────
# These are compiled into the browser bundle — only place PUBLIC values here.

# Public URL of your Supabase project (ends with .supabase.co).
VITE_SUPABASE_URL="https://your-project-ref.supabase.co"

# Supabase anon key — safe to expose; RLS protects the data.
VITE_SUPABASE_ANON_KEY="eyJhbGciOi…"

# Stripe publishable key — public by design.
VITE_STRIPE_PUBLISHABLE_KEY="pk_test_…"

# Canonical site URL — used in OG tags, Stripe return URLs, email links.
VITE_SITE_URL="https://converter.dishine.it"

# Default language (en | fr | it).
VITE_DEFAULT_LOCALE="en"


# ─── Supabase edge functions (Deno runtime) ────────────────────────────
# Set these in Supabase Dashboard → Project Settings → Edge Functions → Secrets.
# They are NOT read from this file at runtime — this file documents what is needed.

# Supabase service-role key (server-side only — never expose in the browser).
# SUPABASE_URL=<same as VITE_SUPABASE_URL>
# SUPABASE_SERVICE_ROLE_KEY=<service_role JWT>

# ─ AI backend (OpenAI-compatible /chat/completions) ────────────────────
# Defaults to Google Gemini's OpenAI-compatible endpoint.
# Any provider that speaks the OpenAI chat-completions shape works.
# AI_GATEWAY_URL="https://generativelanguage.googleapis.com/v1beta/openai/chat/completions"
# AI_GATEWAY_API_KEY="AIza…"
#
# Backwards-compatible alias — used when AI_GATEWAY_API_KEY is not set:
# GEMINI_API_KEY="AIza…"
#
# Model overrides (optional).
# AI_MODEL_FREE="gemini-2.5-flash"
# AI_MODEL_PRO="gemini-2.5-pro"

# Firecrawl API key — enables JS-rendered URL fetches for Pro users.
# Leave unset to fall back to plain HTTP for all users.
# FIRECRAWL_API_KEY="fc-…"

# Custom User-Agent for URL fetching.
# FETCH_USER_AGENT="Mozilla/5.0 (compatible; YourApp/1.0; +https://yoursite.com)"

# Stripe (server-side only — never expose these values).
# STRIPE_SECRET_KEY="sk_test_…"
# STRIPE_WEBHOOK_SECRET="whsec_…"
# STRIPE_PRICE_PRO_MONTHLY="price_…"
# STRIPE_PRICE_PRO_YEARLY="price_…"

# Request signing & hashing secret (≥ 32 chars).
# Generate with:  openssl rand -hex 48
# HMAC_SECRET="…"

# Operator access passphrase — use a long random string.
# OPS_PASSPHRASE="change-me-to-a-long-random-passphrase"

# Operator email provisioned on first access.
# OPS_EMAIL="ops@example.local"

# Internal service token secret — falls back to HMAC_SECRET if unset.
# INTERNAL_TOKEN_SECRET="…"

# Quota overrides (optional — defaults shown).
# QUOTA_FREE_PER_DAY=5
# QUOTA_PRO_PER_MONTH=500
# RATE_LIMIT_PER_MINUTE=30

# Base URL used for auth redirect links and Stripe return flows.
# SITE_URL="https://converter.dishine.it"


# ─── Analytics (optional) ──────────────────────────────────────────────
# Leave empty to disable. Compatible with Plausible, Umami, Fathom.

# VITE_ANALYTICS_PROVIDER="plausible"
# VITE_ANALYTICS_DOMAIN="converter.yoursite.com"
# VITE_ANALYTICS_SCRIPT_URL="https://plausible.io/js/script.js"


# ─── Developer convenience ─────────────────────────────────────────────
# Local dev only — not referenced in production.

# Skip email verification for local Supabase CLI accounts.
# SUPABASE_AUTH_AUTOCONFIRM=true
